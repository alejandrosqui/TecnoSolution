# Copy this file to .env and fill in the values

APP_NAME=TecnoSolution
APP_ENV=development
SECRET_KEY=change-me-in-production
DEBUG=true

DATABASE_URL=postgresql+asyncpg://tecnosolution:secret@postgres:5433/tecnosolution_db

MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minio_admin
MINIO_SECRET_KEY=minio_secret
MINIO_BUCKET_PHOTOS=work-order-photos
MINIO_BUCKET_DOCS=documents

REDIS_URL=redis://redis:6380/0

JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=7

RESEND_API_KEY=re_xxxx
FROM_EMAIL=no-reply@tecnosolution.com
