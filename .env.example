# Copy this file to .env and fill in all values before running docker compose

# ─── App ────────────────────────────────────────────────────────────────────
APP_NAME=TecnoSolution
APP_ENV=development
SECRET_KEY=change-me-in-production
DEBUG=true

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://tecnosolution:secret@localhost:5433/tecnosolution_db
POSTGRES_USER=tecnosolution
POSTGRES_PASSWORD=secret
POSTGRES_DB=tecnosolution_db

# ─── MinIO ───────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minio_admin
MINIO_SECRET_KEY=minio_secret
MINIO_BUCKET_PHOTOS=work-order-photos
MINIO_BUCKET_DOCS=documents

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6380/0

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=7

# ─── Resend (email) ──────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxx
FROM_EMAIL=no-reply@tecnosolution.com

# ─── Frontend ────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8004
VITE_PUBLIC_URL=http://localhost:5173
